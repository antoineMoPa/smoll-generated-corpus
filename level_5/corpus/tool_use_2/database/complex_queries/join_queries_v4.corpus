{"func_call":"query_with_joins","primary_table":"vehicles","joins":[{"table":"maintenance_logs","on":"vehicles.id = maintenance_logs.vehicle_id","type":"inner"},{"table":"mechanics","on":"maintenance_logs.mechanic_id = mechanics.id","type":"left"}],"select":["vehicles.make","vehicles.model","maintenance_logs.service_date","mechanics.full_name","maintenance_logs.cost"],"where":"maintenance_logs.service_date >= '2024-01-01'","order_by":"maintenance_logs.cost DESC","limit":5}
