{"func_call": "query_with_joins", "primary_table": "shipments", "joins": [{"table": "carriers", "on": "shipments.carrier_id = carriers.id", "type": "inner"}], "select": ["carriers.name", "COUNT(*) as delivery_count", "AVG(shipments.transit_days) as avg_speed"], "where": "shipments.delivered_at >= '2023-05-01'", "order_by": "avg_speed ASC", "limit": 10}
{"rows": [{"name": "Swift Logistics", "delivery_count": 8900, "avg_speed": 1.8}, {"name": "AirFreight Pro", "delivery_count": 5600, "avg_speed": 2.1}, {"name": "Ground Express", "delivery_count": 12000, "avg_speed": 3.5}, {"name": "Ocean Cargo", "delivery_count": 3200, "avg_speed": 14.2}, {"name": "Regional Post", "delivery_count": 9500, "avg_speed": 4.1}], "count": 5, "query_ms": 42, "explain": "Evaluated carrier performance by average transit time for shipments delivered since May 2023."}

{"func_call": "subquery", "primary_table": "events", "joins": [], "select": ["venue_city", "COUNT(*) as event_count", "MAX(ticket_price) as max_ticket"], "where": "ticket_price > (SELECT AVG(ticket_price) FROM events WHERE genre = 'Rock')", "order_by": "event_count DESC", "limit": 8}
{"rows": [{"venue_city": "New York", "event_count": 340, "max_ticket": 250.00}, {"venue_city": "Los Angeles", "event_count": 290, "max_ticket": 220.50}, {"venue_city": "London", "event_count": 210, "max_ticket": 180.00}, {"venue_city": "Tokyo", "event_count": 185, "max_ticket": 195.75}, {"venue_city": "Berlin", "event_count": 160, "max_ticket": 150.25}], "count": 5, "query_ms": 31, "explain": "Identified cities hosting events with ticket prices exceeding the Rock genre average."}

{"func_call": "query_with_joins", "primary_table": "claims", "joins": [{"table": "policies", "on": "claims.policy_id = policies.id", "type": "inner"}, {"table": "agents", "on": "policies.agent_id = agents.id", "type": "inner"}], "select": ["agents.name", "SUM(claims.amount) as total_payout", "COUNT(claims.id) as claim_freq"], "where": "claims.status = 'approved' AND claims.filed_date BETWEEN '2023-01-01' AND '2023-12-31'", "order_by": "total_payout DESC", "limit": 5}
{"rows": [{"name": "Sarah Jenkins", "total_payout": 450000.00, "claim_freq": 22}, {"name": "Marcus Thorne", "total_payout": 385000.50, "claim_freq": 18}, {"name": "Elena Rodriguez", "total_payout": 310000.25, "claim_freq": 25}, {"name": "David Kim", "total_payout": 275000.00, "claim_freq": 15}, {"name": "Priya Patel", "total_payout": 240000.75, "claim_freq": 19}], "count": 5, "query_ms": 55, "explain": "Aggregated approved claim payouts and frequency per insurance agent for the 2023 fiscal year."}

{"func_call": "query_with_joins", "primary_table": "commutes", "joins": [{"table": "stations", "on": "commutes.origin_station = stations.id", "type": "inner"}], "select": ["stations.zone", "AVG(commutes.duration_mins) as avg_time", "COUNT(*) as trip_volume"], "where": "commutes.date >= '2023-06-01' AND commutes.time_of_day = 'Morning'", "order_by": "avg_time DESC", "limit": 10}
{"rows": [{"zone": "Outer Suburbs", "avg_time": 52.4, "trip_volume": 15000}, {"zone": "Mid-City", "avg_time": 38.1, "trip_volume": 22000}, {"zone": "Downtown", "avg_time": 25.5, "trip_volume": 31000}, {"zone": "Industrial Park", "avg_time": 45.2, "trip_volume": 8500}, {"zone": "University District", "avg_time": 30.8, "trip_volume": 12000}], "count": 5, "query_ms": 38, "explain": "Analyzed morning commute durations by station zone starting from June 2023."}

{"func_call": "query_with_joins", "primary_table": "reviews", "joins": [{"table": "users", "on": "reviews.user_id = users.id", "type": "inner"}], "select": ["users.subscription_level", "AVG(reviews.rating) as avg_rating", "COUNT(reviews.id) as review_count"], "where": "reviews.created_at > NOW() - INTERVAL '30 days'", "order_by": "review_count DESC", "limit": 5}
