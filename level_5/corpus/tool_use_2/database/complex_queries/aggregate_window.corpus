{"func_call": "subquery", "primary_table": "students", "joins": [{"table": "grades", "on": "students.id = grades.student_id", "type": "inner"}], "select": ["students.major", "AVG(grades.score) as major_avg", "MAX(grades.score) as top_score"], "where": "grades.semester = 'Fall 2023' AND grades.score > (SELECT AVG(score) FROM grades WHERE semester = 'Fall 2023')", "order_by": "major_avg DESC", "limit": 5}
