{"func_call": "subquery", "primary_table": "products", "joins": [], "select": ["category", "COUNT(*) as product_count", "AVG(price) as avg_price"], "where": "price > (SELECT AVG(price) FROM products WHERE category = 'Electronics')", "order_by": "product_count DESC", "limit": 10}
