{"func_call": "query_with_joins", "primary_table": "logs", "joins": [{"table": "services", "on": "logs.service_id = services.id", "type": "inner"}], "select": ["services.name", "COUNT(*) as error_count", "DATE_TRUNC('hour', logs.timestamp) as hour_bucket"], "where": "logs.level = 'ERROR' AND logs.timestamp >= NOW() - INTERVAL '24 hours'", "order_by": "hour_bucket DESC, error_count DESC", "limit": 20}
