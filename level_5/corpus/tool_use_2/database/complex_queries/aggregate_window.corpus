{"func_call": "query_with_joins", "primary_table": "employees", "joins": [{"table": "departments", "on": "employees.dept_id = departments.id", "type": "inner"}, {"table": "salaries", "on": "employees.id = salaries.emp_id", "type": "inner"}], "select": ["departments.name", "AVG(salaries.amount) as avg_salary", "MAX(salaries.amount) as max_salary", "MIN(salaries.amount) as min_salary"], "where": "salaries.effective_date > '2022-06-01'", "order_by": "avg_salary DESC", "limit": 5}
