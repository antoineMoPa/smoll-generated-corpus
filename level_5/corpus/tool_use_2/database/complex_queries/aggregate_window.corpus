{"func_call": "query_with_joins", "primary_table": "orders", "joins": [{"table": "customers", "on": "orders.customer_id = customers.id", "type": "inner"}], "select": ["customers.region", "SUM(orders.total_amount) as total_revenue", "COUNT(orders.id) as order_count"], "where": "orders.order_date >= '2023-01-01'", "order_by": "total_revenue DESC", "limit": 10}
