Available Tools: get_order_status | track_shipment | get_order_history | cancel_order
Call Schema: { "func_call": "string", "order_id": "string", "tracking_number": "string" }
Response Schema: { "order_id": "string", "status": "string", "estimated_delivery": "string", "tracking_events": [{ "date": "string", "location": "string", "status": "string" }] }
---
