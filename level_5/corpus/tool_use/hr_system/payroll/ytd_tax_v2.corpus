Available Tools: get_payslip | get_salary_info | run_payroll | update_tax_info | get_ytd_earnings
Call Schema: { "func_call": "string", "employee_id": "string", "period": "string" }
Response Schema: { "employee_id": "string", "period": "string", "gross": number, "deductions": number, "net": number, "currency": "string" }
