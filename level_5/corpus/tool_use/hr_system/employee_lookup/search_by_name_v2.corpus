Available Tools: search_employee | get_employee_by_id | get_org_chart | list_employees_by_department
Call Schema: { "func_call": "string", "query": "string", "department": "string", "employee_id": "string" }
Response Schema: { "employees": [{ "id": "string", "name": "string", "title": "string", "department": "string", "email": "string", "manager": "string" }] }
