Available Tools: update_record | update_batch | soft_delete | restore_record
Call Schema: { "func_call": "string", "table": "string", "id": number, "data": {}, "where": "string" }
Response Schema: { "affected_rows": number, "status": "string", "updated_at": "string" }
---
Question: Modify the first name for user ID 5012 to 'Alexandra'.
Call: { "func_call": "update_record", "table": "users", "id": 5012, "data": { "first_name": "Alexandra" }, "where": "id = 5012" }
Response: { "affected_rows": 1, "status": "success", "updated_at": "2023-11-05T09:12:44Z" }

Question: Set the order status for ID 3345 to 'processing'.
Call: { "func_call": "update_record", "table": "orders", "id": 3345, "data": { "status": "processing", "processed_by": "system_auto" }, "where": "id = 3345" }
Response: { "affected_rows": 1, "status": "success", "updated_at": "2023-11-05T09:13:22Z" }

Question: Raise the cost of item ID 204 to 89.95.
Call: { "func_call": "update_record", "table": "products", "id": 204, "data": { "price": 89.95, "currency": "EUR" }, "where": "id = 204" }
Response: { "affected_rows": 1, "status": "success", "updated_at": "2023-11-05T09:14:08Z" }

Question: Update the middle initial for user ID 774 to 'J'.
Call: { "func_call": "update_record", "table": "users", "id": 774, "data": { "middle_initial": "J" }, "where": "id = 774" }
Response: { "affected_rows": 1, "status": "success", "updated_at": "2023-11-05T09:15:33Z" }

Question: Flag order ID 1120 as 'cancelled' due to stock shortage.
Call: { "func_call": "update_record", "table": "orders", "id": 1120, "data": { "status": "cancelled", "cancellation_reason": "Out of stock" }, "where": "id = 1120" }
