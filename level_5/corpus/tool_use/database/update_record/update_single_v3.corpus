Call: { "func_call": "update_record", "table": "orders", "id": 5588, "data": { "billing_address": "45 Oak Lane, Dublin", "city": "Dublin" }, "where": "id = 5588" }
Response: { "affected_rows": 1, "status": "success", "updated_at": "2023-11-05T09:19:45Z" }

Question: Discount product ID 337 to 9.99 for clearance.
Call: { "func_call": "update_record", "table": "products", "id": 337, "data": { "price": 9.99, "clearance_flag": true }, "where": "id = 337" }
