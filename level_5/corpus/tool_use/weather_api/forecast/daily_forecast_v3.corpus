Available Tools: get_forecast_daily | get_forecast_hourly | get_forecast_weekly
Call Schema: { "func_call": "string", "location": "string", "days": number, "unit": "string" }
Response Schema: { "location": "string", "forecast": [{ "date": "string", "high": number, "low": number, "condition": "string" }] }
---
Question: What will the weather be like in Seattle over the next 4 days?
Call: { "func_call": "get_forecast_daily", "location": "Seattle", "days": 4, "unit": "fahrenheit" }
Response: { "location": "Seattle", "forecast": [{ "date": "2023-11-01", "high": 55, "low": 48, "condition": "Rain" }, { "date": "2023-11-02", "high": 53, "low": 46, "condition": "Cloudy" }, { "date": "2023-11-03", "high": 56, "low": 49, "condition": "Partly Cloudy" }, { "date": "2023-11-04", "high": 58, "low": 50, "condition": "Sunny" }] }

