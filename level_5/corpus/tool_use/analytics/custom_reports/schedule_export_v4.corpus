Response: { "report_id": "rpt_app_crashes_48h", "name": "Mobile App Crash Analysis", "rows": [{"os_version": "iOS 17", "app_version": "2.4.1", "crash_count": 145, "affected_users": 132}, {"os_version": "Android 14", "app_version": "2.4.0", "crash_count": 89, "affected_users": 85}], "total_rows": 2, "generated_at": "2023-10-06T15:10:22Z" }

