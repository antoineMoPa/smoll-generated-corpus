Call: { "func_call": "cancel_subscription", "customer_id": "usr_5510", "plan_id": "premium", "trial_days": 0 }
Response: { "subscription_id": "sub_3829y", "status": "canceled", "plan": "premium", "current_period_end": "2024-01-05T16:20:00Z" }

