Call: { "func_call": "attach_volume", "volume_id": "vol-cold-hist-77", "instance_id": "i-archive-vault-02", "size_gb": 0 }
Response: { "volume_id": "vol-cold-hist-77", "size_gb": 2048, "state": "in-use", "attached_to": "i-archive-vault-02" }

