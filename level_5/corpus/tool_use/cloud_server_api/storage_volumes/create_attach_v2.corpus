Call: { "func_call": "attach_volume", "volume_id": "vol-compliance-archive-77", "instance_id": "i-audit-secure-02", "size_gb": 0 }
Response: { "volume_id": "vol-compliance-archive-77", "size_gb": 5120, "state": "in-use", "attached_to": "i-audit-secure-02" }

