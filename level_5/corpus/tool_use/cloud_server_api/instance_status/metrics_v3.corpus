Call: { "func_call": "get_instance_metrics", "instance_id": "queue-worker-09", "region": "ap-south-1", "filter": "network,memory" }
Response: { "instances": [{ "id": "queue-worker-09", "type": "t3.large", "state": "running", "ip": "192.168.99.88" }] }

