Available Tools: create_network | list_networks | create_volume | list_volumes | mount_volume
Call Schema: { "func_call": "string", "name": "string", "driver": "string", "container_id": "string", "mount_path": "string" }
Response Schema: { "id": "string", "name": "string", "driver": "string", "scope": "string", "containers": ["string"] }
