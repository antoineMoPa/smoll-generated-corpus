Response: { "results": [{ "test": "PSA", "value": 2.1, "unit": "ng/mL", "reference_range": "0.0-4.0", "status": "normal" }, { "test": "PSA", "value": 2.3, "unit": "ng/mL", "reference_range": "0.0-4.0", "status": "normal" }, { "test": "PSA", "value": 2.2, "unit": "ng/mL", "reference_range": "0.0-4.0", "status": "normal" }] }

