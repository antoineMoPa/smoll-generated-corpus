Response: { "results": [{ "test": "TSH", "value": 2.5, "unit": "mIU/L", "reference_range": "0.4-4.0", "status": "normal" }, { "test": "TSH", "value": 4.8, "unit": "mIU/L", "reference_range": "0.4-4.0", "status": "high" }, { "test": "TSH", "value": 3.1, "unit": "mIU/L", "reference_range": "0.4-4.0", "status": "normal" }] }

