Available Tools: get_prescriptions | request_refill | check_drug_interaction | get_medication_info
Call Schema: { "func_call": "string", "patient_id": "string", "medication": "string", "dosage": "string" }
Response Schema: { "prescription_id": "string", "medication": "string", "dosage": "string", "refills_remaining": number, "status": "string" }
