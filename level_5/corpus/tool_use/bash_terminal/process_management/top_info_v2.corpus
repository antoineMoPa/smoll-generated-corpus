Response: { "processes": [{ "pid": 8812, "name": "mongod", "cpu": 14.2, "mem": 28.3 }, { "pid": 3340, "name": "vscode", "cpu": 22.7, "mem": 15.6 }, { "pid": 9102, "name": "redis-server", "cpu": 12.1, "mem": 8.9 }, { "pid": 2290, "name": "apache2", "cpu": 3.4, "mem": 5.1 }, { "pid": 7821, "name": "ffmpeg", "cpu": 89.3, "mem": 4.2 }] }

