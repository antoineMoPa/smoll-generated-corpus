Available Tools: transfer_funds | schedule_transfer | cancel_transfer | get_transfer_status
Call Schema: { "func_call": "string", "from_account": "string", "to_account": "string", "amount": number, "currency": "string", "scheduled_date": "string" }
Response Schema: { "transfer_id": "string", "status": "string", "amount": number, "estimated_arrival": "string" }
