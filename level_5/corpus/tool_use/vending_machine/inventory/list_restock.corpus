Available Tools: list_inventory | restock_item | get_low_stock | update_price
Call Schema: { "func_call": "string", "slot_id": "string", "quantity": number, "price": number }
Response Schema: { "inventory": [{ "slot_id": "string", "name": "string", "quantity": number, "price": number }] }
---
