Available Tools: search_places | get_place_details | find_nearby | get_place_reviews
Call Schema: { "func_call": "string", "query": "string", "location": "string", "radius_km": number, "type": "string" }
Response Schema: { "places": [{ "id": "string", "name": "string", "address": "string", "rating": number, "open_now": boolean }], "total": number }
