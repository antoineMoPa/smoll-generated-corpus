Available Tools: create_playlist | add_to_playlist | remove_from_playlist | delete_playlist | list_playlists
Call Schema: { "func_call": "string", "playlist_id": "string", "name": "string", "track_id": "string" }
Response Schema: { "playlist_id": "string", "name": "string", "track_count": number, "duration_seconds": number }
